NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use ONE of these public browser keys. Supabase projects may label it anon or publishable.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional for trusted server-only jobs. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables authenticated Playwright flows.
E2E_AUTH_EMAIL=admin@example.com
E2E_AUTH_PASSWORD=your-test-password
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
